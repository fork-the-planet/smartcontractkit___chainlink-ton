{
  "name": "@chainlink/contracts-ton",
  "private": true,
  "version": "0.0.1",
  "description": "Chainlink TON smart contracts",
  "author": "Chainlink Labs",
  "license": "BUSL-1.1",
  "files": [
    "build",
    "contracts",
    "wrappers"
  ],
  "scripts": {
    "bp": "blueprint",
    "start": "blueprint run",
    "clean": "[ -d build ] && rm -rf build || true",
    "build": "yarn clean && blueprint build --all",
    "test": "jest --verbose",
    "test-coverage": "COVERAGE=true jest",
    "generate-coverage-reports": "ts-node tests/coverage/scriptMergeCoverageIntoHtmlReports.ts",
    "fmt:check": "yarn fmt-contracts:check && yarn fmt-typescript:check",
    "fmt": "yarn fmt-contracts && yarn fmt-typescript",
    "fmt-contracts:check": "tact-fmt --check contracts",
    "fmt-contracts": "tact-fmt --write contracts",
    "fmt-typescript:check": "prettier --check .",
    "fmt-typescript": "prettier --write .",
    "ccip-gas-report": "blueprint test --gas-report -- --config ccip-gas-report.config.ts"
  },
  "dependencies": {
    "@ethersproject/keccak256": "^5.8.0",
    "ethers": "^6.15.0"
  },
  "devDependencies": {
    "@changesets/cli": "~2.29.6",
    "@tact-lang/compiler": "1.6.13",
    "@ton-community/func-js": "^0.10.0",
    "@ton/blueprint": "^0.41.0",
    "@ton/core": "^0.62.0",
    "@ton/crypto": "^3.3.0",
    "@ton/sandbox": "^0.39.0",
    "@ton/test-utils": "^0.12.0",
    "@ton/tolk-js": "^1.2.0",
    "@ton/ton": "^16.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "crc-32": "^1.2.2",
    "jest": "^30.0.5",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "zlib": "^1.0.5"
  }
}
